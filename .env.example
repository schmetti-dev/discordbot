# Discord Bot Token
# Zu finden unter: https://discord.com/developers/applications -> Deine App -> Bot -> Token
DISCORD_TOKEN=dein_token_hier

# Discord Guild ID (Server-ID) für schnelle Slash Command Registrierung während der Entwicklung
# Im Produktivbetrieb kann diese Zeile entfernt werden (globale Commands, dauert ~1h)
# Rechtsklick auf Server-Icon -> ID kopieren (Entwicklermodus muss aktiviert sein)
DISCORD_GUILD_ID=deine_server_id_hier

# Rolle die /buch-setzen ausführen darf (Name der Rolle, exakt wie in Discord)
ADMIN_ROLE_NAME=Buchclub-Admin
